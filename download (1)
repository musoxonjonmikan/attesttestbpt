import React, { useState } from "react";
import { motion } from "motion/react";
import { User, Key, ArrowRight, Bot, ShieldCheck, ClipboardCheck } from "lucide-react";

interface LoginScreenProps {
  onStartTest: (name: string, code: string) => void;
  isLoading: boolean;
}

export default function LoginScreen({ onStartTest, isLoading }: LoginScreenProps) {
  const [name, setName] = useState("");
  const [code, setCode] = useState("");
  const [error, setError] = useState<string | null>(null);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setError(null);

    if (!name.trim()) {
      setError("Iltimos, ismingizni kiriting!");
      return;
    }

    if (!code.trim()) {
      setError("Iltimos, test kodini kiriting!");
      return;
    }

    // Attempt to verify the code against backend
    try {
      const response = await fetch(`/api/test/${code.trim()}`);
      if (!response.ok) {
        const errData = await response.json();
        setError(errData.error || "Ushbu test kodi topilmadi!");
        return;
      }
      
      const testData = await response.json();
      onStartTest(name.trim(), testData.code);
    } catch (err) {
      setError("Server bilan aloqa bog'lab bo'lmadi. Iltimos qayta urinib ko'ring.");
    }
  };

  const handleUseDemo = () => {
    setName("Test Foydalanuvchi");
    setCode("7777");
    setError(null);
  };

  return (
    <div className="flex-1 flex flex-col justify-between p-5 selection:bg-indigo-500 selection:text-white select-none" id="login-container">
      {/* Header */}
      <header className="w-full py-2 flex items-center justify-between border-b border-slate-900 pb-4 mb-4" id="login-header">
        <div className="flex items-center gap-2.5" id="brand-logo">
          <div className="w-9 h-9 rounded-xl bg-gradient-to-tr from-indigo-500 via-purple-500 to-pink-500 flex items-center justify-center shadow-lg shadow-indigo-500/20">
            <ClipboardCheck className="w-4.5 h-4.5 text-white" />
          </div>
          <div>
            <h1 className="font-display text-base font-bold tracking-tight bg-gradient-to-r from-white via-indigo-200 to-slate-400 bg-clip-text text-transparent">Attest Test</h1>
            <span className="font-mono text-[8px] text-indigo-400 block tracking-wider -mt-0.5">ONLINE QUIZ SYSTEM</span>
          </div>
        </div>
        <div className="flex items-center gap-1.5 text-[10px] text-slate-400 bg-slate-900 border border-slate-800/80 px-2.5 py-1 rounded-full" id="admin-bot-badge">
          <Bot className="w-3.5 h-3.5 text-indigo-400 animate-pulse" />
          <span><span className="font-medium text-slate-200">@attesttestbot</span></span>
        </div>
      </header>

      {/* Main Container */}
      <main className="flex-1 flex items-center justify-center my-2" id="login-main">
        <motion.div 
          initial={{ opacity: 0, scale: 0.97 }}
          animate={{ opacity: 1, scale: 1 }}
          transition={{ duration: 0.3 }}
          className="w-full bg-slate-900/30 border border-slate-800/80 rounded-2xl p-6 relative shadow-2xl overflow-hidden shadow-indigo-950/10"
          id="login-card"
        >
          {/* Subtle Pink/Purple Radial Backdrop shimmer */}
          <div className="absolute -top-10 -right-10 w-24 h-24 bg-pink-500/10 rounded-full blur-2xl pointer-events-none"></div>

          <div className="text-center mb-6" id="login-title-block">
            <h2 className="text-xl font-display font-bold tracking-tight text-white mb-1">Platformaga kirish</h2>
            <p className="text-slate-400 text-xs">Javoblar o'qituvchi telegramiga yuboriladi</p>
          </div>

          <form onSubmit={handleSubmit} className="space-y-4" id="login-form">
            {/* Name Input */}
            <div className="space-y-1.5" id="name-input-group">
              <label htmlFor="name-input" className="block text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                Ismingizni kiriting
              </label>
              <div className="relative">
                <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-500">
                  <User className="h-4 w-4" />
                </div>
                <input
                  id="name-input"
                  type="text"
                  required
                  placeholder="Masalan: Dilshodbek"
                  value={name}
                  onChange={(e) => setName(e.target.value)}
                  className="block w-full pl-9 pr-3 py-2.5 bg-slate-950/80 border border-slate-800 rounded-xl text-slate-100 placeholder-slate-600 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 text-xs transition-all"
                />
              </div>
            </div>

            {/* Code Input */}
            <div className="space-y-1.5" id="code-input-group">
              <div className="flex justify-between items-center">
                <label htmlFor="code-input" className="block text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                  Test kodini kiriting
                </label>
                <button
                  type="button"
                  onClick={handleUseDemo}
                  className="text-[9px] text-indigo-400 hover:text-indigo-300 transition-colors font-bold border border-indigo-500/15 bg-indigo-500/5 px-1.5 py-0.5 rounded cursor-pointer"
                  id="demo-code-btn"
                >
                  Demo (7777)
                </button>
              </div>
              <div className="relative">
                <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-500">
                  <Key className="h-4 w-4" />
                </div>
                <input
                  id="code-input"
                  type="text"
                  required
                  maxLength={10}
                  placeholder="7777"
                  value={code}
                  onChange={(e) => setCode(e.target.value)}
                  className="block w-full pl-9 pr-3 py-2.5 bg-slate-950/80 border border-slate-800 rounded-xl text-slate-100 placeholder-slate-600 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 text-center tracking-widest font-mono text-sm font-bold transition-all"
                />
              </div>
            </div>

            {error && (
              <motion.div 
                initial={{ opacity: 0, y: -5 }}
                animate={{ opacity: 1, y: 0 }}
                className="bg-red-950/20 border border-red-500/20 text-red-400 p-2.5 rounded-xl text-[10px] flex items-center gap-2"
                id="login-error-alert"
              >
                <ShieldCheck className="w-3.5 h-3.5 shrink-0 text-red-500" />
                <span>{error}</span>
              </motion.div>
            )}

            {/* Submit Button */}
            <button
              id="submit-login-btn"
              type="submit"
              disabled={isLoading}
              className="w-full flex items-center justify-center gap-2 py-3 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 hover:opacity-90 text-white rounded-xl font-bold shadow-lg shadow-indigo-500/15 transition-all active:scale-[0.98] disabled:opacity-50 cursor-pointer text-xs uppercase tracking-wider"
            >
              {isLoading ? (
                <div className="w-4 h-4 rounded-full border-2 border-white/30 border-t-white animate-spin"></div>
              ) : (
                <>
                  <span>Testni boshlash</span>
                  <ArrowRight className="w-4 h-4" />
                </>
              )}
            </button>
          </form>

          {/* Quick Notice */}
          <div className="mt-5 pt-4 border-t border-slate-900 block text-[10px] text-slate-500 space-y-1.5 text-center leading-normal" id="bot-hint">
            <p>
              Ushbu tezkor tizim o'quvchilar va abituriyentlar uchun maxsus test tekshirish imkoniyatini taqdim etadi.
            </p>
            <p className="font-mono text-[9px] text-indigo-400 bg-indigo-500/5 py-1 rounded border border-indigo-500/10 inline-block px-2">
              Yangi test kodi admin bot orqali yaratiladi.
            </p>
          </div>
        </motion.div>
      </main>

      {/* Footer */}
      <footer className="py-2 mt-2 border-t border-slate-900 text-center text-[10px] text-slate-500 flex flex-col items-center justify-center gap-1" id="login-footer">
        <div>
          © {new Date().getFullYear()} Attest Test Platform.
        </div>
        <div className="flex items-center gap-1 text-[9px] text-slate-600">
          <span>Xavfsiz va tezkor Mini App</span>
          <span className="w-1 h-1 rounded-full bg-emerald-500 animate-ping"></span>
        </div>
      </footer>
    </div>
  );
}
